{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Style Rubric Evaluation",
  "description": "Schema for evaluating skill output style and quality",
  "type": "object",
  "properties": {
    "overall_pass": {
      "type": "boolean",
      "description": "Whether the output passes overall style requirements"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Overall style score from 0-100"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for this check"
          },
          "pass": {
            "type": "boolean",
            "description": "Whether this specific check passed"
          },
          "notes": {
            "type": "string",
            "description": "Explanation of the result and any issues"
          }
        },
        "required": ["id", "pass", "notes"],
        "additionalProperties": false
      },
      "description": "Array of individual style checks"
    }
  },
  "required": ["overall_pass", "score", "checks"],
  "additionalProperties": false
}
