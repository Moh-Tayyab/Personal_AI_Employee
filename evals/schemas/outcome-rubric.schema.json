{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Outcome Rubric Evaluation",
  "description": "Schema for evaluating whether skill achieved its intended outcome",
  "type": "object",
  "properties": {
    "outcome_achieved": {
      "type": "boolean",
      "description": "Whether the primary outcome was achieved"
    },
    "outcome_type": {
      "type": "string",
      "enum": ["email_sent", "draft_created", "search_completed", "no_trigger", "other"],
      "description": "Type of outcome expected"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Overall outcome score from 0-100"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for this check"
          },
          "pass": {
            "type": "boolean",
            "description": "Whether this specific check passed"
          },
          "evidence": {
            "type": "string",
            "description": "Evidence from trace or artifacts supporting the result"
          },
          "notes": {
            "type": "string",
            "description": "Explanation of the result"
          }
        },
        "required": ["id", "pass", "evidence", "notes"],
        "additionalProperties": false
      },
      "description": "Array of individual outcome checks"
    },
    "artifacts_created": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of files or artifacts created during execution"
    }
  },
  "required": ["outcome_achieved", "outcome_type", "score", "checks"],
  "additionalProperties": false
}
