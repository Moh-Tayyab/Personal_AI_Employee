# Personal AI Employee - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# CLAUDE CODE CONFIGURATION
# ============================================
# Your Claude API key (if using API directly)
# CLAUDE_API_KEY=your-claude-api-key

# ============================================
# GMAIL WATCHER (Optional)
# ============================================
# Get from Google Cloud Console
# GMAIL_CLIENT_ID=your-client-id
# GMAIL_CLIENT_SECRET=your-client-secret
# GMAIL_REDIRECT_URI=http://localhost
# GMAIL_CREDENTIALS_PATH=/path/to/credentials.json

# ============================================
# VERCEL DEPLOYMENT (Optional - for fix-ticket)
# ============================================
# Get from Vercel dashboard
# VERCEL_TOKEN=your-vercel-token
# VERCEL_TEAM_ID=your-team-id
# VERCEL_PROJECT_ID=your-project-id

# ============================================
# ODOO INTEGRATION (Optional - Gold tier)
# ============================================
# Odoo Community instance
# ODOO_URL=http://localhost:8069
# ODOO_DB=your-database
# ODOO_USERNAME=admin
# ODOO_API_KEY=your-api-key

# ============================================
# SOCIAL MEDIA (Optional - Gold tier)
# ============================================
# Twitter/X
# TWITTER_API_KEY=your-api-key
# TWITTER_API_SECRET=your-api-secret
# TWITTER_ACCESS_TOKEN=your-access-token
# TWITTER_ACCESS_TOKEN_SECRET=your-secret

# LinkedIn
# LINKEDIN_CLIENT_ID=your-client-id
# LINKEDIN_CLIENT_SECRET=your-client-secret
# LINKEDIN_ACCESS_TOKEN=your-access-token

# Facebook
# FACEBOOK_APP_ID=your-app-id
# FACEBOOK_APP_SECRET=your-app-secret
# FACEBOOK_ACCESS_TOKEN=your-access-token

# ============================================
# SERPER API (Google Search - Optional)
# ============================================
# Get from https://serper.dev
# SERPER_API_KEY=your-serper-api-key

# ============================================
# FIRECRAWL (Web Scraping - Optional)
# ============================================
# Get from https://firecrawl.dev
# FIRECRAWL_API_KEY=your-firecrawl-api-key

# ============================================
# SYSTEM CONFIGURATION
# ============================================
# Vault path (absolute path to Obsidian vault)
VAULT_PATH=/home/muhammad_tayyab/hackathon/Personal_AI_Employee/vault

# Development mode (prevents real actions)
DEV_MODE=false

# Dry run mode (logs actions without executing)
DRY_RUN=false

# Max iterations for Ralph Wiggum loop
MAX_RALPH_ITERATIONS=10

# Watcher check interval (seconds)
WATCHER_INTERVAL=30

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_DIR=/home/muhammad_tayyab/hackathon/Personal_AI_Employee/vault/Logs

# ============================================
# NOTIFICATION CONFIGURATION (Optional)
# ============================================
# For sending alerts to human
# NOTIFY_EMAIL=your-email@example.com
# NOTIFY_WHATSAPP=+1234567890

# ============================================
# SECURITY
# ============================================
# Approval threshold for payments
PAYMENT_APPROVAL_THRESHOLD=500

# Approval threshold for emails (number of recipients)
EMAIL_APPROVAL_THRESHOLD=10

# Auto-approve P2/P3 bug fixes
AUTO_APPROVE_LOW_PRIORITY_BUGS=true
