# Environment Configuration Template
# Copy to .env and fill in your values

# Claude Code Configuration
ANTHROPIC_API_KEY=your_api_key_here

# Gmail API (obtain from Google Cloud Console)
GMAIL_CLIENT_ID=your_client_id
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_TOKEN_PATH=./vault/secrets/gmail_token.json
GMAIL_CREDENTIALS_PATH=./vault/secrets/gmail_credentials.json

# WhatsApp Session
WHATSAPP_SESSION_PATH=./vault/secrets/whatsapp_session

# Database / Odoo (if using Gold tier)
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_database
ODOO_USERNAME=your_username
ODOO_API_KEY=your_api_key

# Social Media (if using Gold tier)
LINKEDIN_COOKIES_PATH=./vault/secrets/linkedin_cookies.json
TWITTER_COOKIES_PATH=./vault/secrets/twitter_cookies.json

# Security
DRY_RUN=true
MAX_DAILY_ACTIONS=50
REQUIRE_APPROVAL_ABOVE=100

# Paths
VAULT_PATH=./vault
LOG_PATH=./vault/Logs
